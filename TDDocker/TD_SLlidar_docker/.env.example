# Environment variables for SLlidar ROS2 + OSC Bridge
# Copy this file to .env and set your own values

# --- LIDAR Connection ---
# Channel type: serial, tcp, or udp
LIDAR_CHANNEL_TYPE=serial

# Serial connection (A1, A2, A3, S1, S2, S3, C1)
LIDAR_SERIAL_PORT=/dev/ttyUSB0
LIDAR_BAUDRATE=115200

# TCP connection (S1-TCP, S2E)
LIDAR_TCP_IP=192.168.0.7
LIDAR_TCP_PORT=20108

# UDP connection (T1)
LIDAR_UDP_IP=192.168.11.2
LIDAR_UDP_PORT=8089

# Scan mode: Standard, Express, Boost, DenseBoost (leave empty for default)
LIDAR_SCAN_MODE=

# --- OSC Output ---
# Host where TouchDesigner is running
OSC_HOST=host.docker.internal
# UDP port for OSC messages
OSC_PORT=7000
# Output format: polar, cartesian, or both
OSC_FORMAT=polar

# --- ROS2 ---
ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=1

# --- Container ---
COMPOSE_PROJECT_NAME=sllidar

# --- Logging ---
LOG_LEVEL=INFO
